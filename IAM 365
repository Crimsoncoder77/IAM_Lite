def init_db(db_path: str = "iam.db") -> sqlite3.Connection:
    conn = sqlite3.connect(db_path)
    c = conn.cursor()
    c.executescript("""
        CREATE TABLE IF NOT EXISTS users (
            id             TEXT PRIMARY KEY,
            displayName    TEXT,
            email          TEXT,
            lastLogin      TEXT,
            accountEnabled INTEGER
        );
        CREATE TABLE IF NOT EXISTS roles (
            roleName TEXT,
            userId   TEXT,
            PRIMARY KEY (roleName, userId)
        );
    """)
    conn.commit()
    return conn


def save_users(conn: sqlite3.Connection, users: list):
    c = conn.cursor()
    c.execute("DELETE FROM users")
    c.executemany(
        "INSERT OR REPLACE INTO users VALUES (?,?,?,?,?)",
        [(u["id"], u["displayName"], u["email"],
          u["lastLogin"], int(u["accountEnabled"])) for u in users]
    )
    conn.commit()


def save_roles(conn: sqlite3.Connection, assignments: list):
    c = conn.cursor()
    c.execute("DELETE FROM roles")
    c.executemany(
        "INSERT OR REPLACE INTO roles VALUES (?,?)",
        [(a["roleName"], a["userId"]) for a in assignments]
    )
    conn.commit()


# ─────────────────────────────────────────────────────────
# 5. RISK LOGIC
# ─────────────────────────────────────────────────────────

def parse_date(dt_str: str | None) -> datetime.datetime | None:
    if not dt_str:
        return None
    for fmt in ("%Y-%m-%dT%H:%M:%SZ", "%Y-%m-%dT%H:%M:%S.%fZ",
                "%Y-%m-%dT%H:%M:%S+00:00"):
        try:
            return datetime.datetime.strptime(dt_str, fmt)
        except ValueError:
            continue
    return None


def analyze_risks(users: list, assignments: list) -> list:
    """
    Apply risk rules to each user.
    Returns enriched user list with flags.
    """
    now       = datetime.datetime.utcnow()
    admin_ids = {a["userId"] for a in assignments}  # set of user IDs with any role

    # Build a map of userId → list of role names
    roles_map: dict[str, list] = {}
    for a in assignments:
        roles_map.setdefault(a["userId"], []).append(a["roleName"])

    enriched = []
    for u in users:
        last_login_dt = parse_date(u["lastLogin"])
        days_since    = (now - last_login_dt).days if last_login_dt else None

        is_inactive       = days_since is not None and days_since > INACTIVE_DAYS
        is_admin          = u["id"] in admin_ids
        is_high_risk      = is_inactive and is_admin
        is_security_issue = (not u["accountEnabled"]) and is_admin

        risk_flags = []
        if is_inactive:       risk_flags.append("INACTIVE")
        if is_admin:          risk_flags.append("ADMIN")
        if is_high_risk:      risk_flags.append("HIGH_RISK")
        if is_security_issue: risk_flags.append("SECURITY_ISSUE")

        enriched.append({
            **u,
            "daysSinceLogin":   days_since,
            "isInactive":       is_inactive,
            "isAdmin":          is_admin,
            "isHighRisk":       is_high_risk,
            "isSecurityIssue":  is_security_issue,
            "riskFlags":        risk_flags,
            "roles":            roles_map.get(u["id"], []),
        })

    return enriched


# ─────────────────────────────────────────────────────────
# 6. REPORTING
# ─────────────────────────────────────────────────────────

def build_report(enriched: list) -> dict:
    total         = len(enriched)
    admins        = [u for u in enriched if u["isAdmin"]]
    inactive      = [u for u in enriched if u["isInactive"]]
    high_risk     = [u for u in enriched if u["isHighRisk"]]
    sec_issues    = [u for u in enriched if u["isSecurityIssue"]]

    return {
        "generatedAt":       datetime.datetime.utcnow().isoformat() + "Z",
        "summary": {
            "totalUsers":        total,
            "totalAdmins":       len(admins),
            "inactiveUsers":     len(inactive),
            "highRiskUsers":     len(high_risk),
            "securityIssues":    len(sec_issues),
        },
        "highRiskUsers":     high_risk,
        "securityIssues":    sec_issues,
        "allUsers":          enriched,
    }


def print_summary(report: dict):
    s = report["summary"]
    print("\n" + "═" * 52)
    print("  📊  Microsoft 365 IAM Report")
    print("═" * 52)
    print(f"  Total users        : {s['totalUsers']}")
    print(f"  Total admins       : {s['totalAdmins']}")
    print(f"  Inactive users     : {s['inactiveUsers']}  (>{INACTIVE_DAYS} days)")
    print(f"  High-risk accounts : {s['highRiskUsers']}  (inactive + admin)")
    print(f"  Security issues    : {s['securityIssues']}  (disabled + has roles)")
    print("─" * 52)

    if report["highRiskUsers"]:
        print("  ⚠️  HIGH-RISK USERS:")
        for u in report["highRiskUsers"]:
            days = u.get("daysSinceLogin", "?")
            print(f"    • {u['displayName']} <{u['email']}>"
                  f"  [{days}d ago]  Roles: {', '.join(u['roles'])}")

    if report["securityIssues"]:
        print("  🚨  SECURITY ISSUES (disabled account still holds roles):")
        for u in report["securityIssues"]:
            print(f"    • {u['displayName']} <{u['email']}>"
                  f"  Roles: {', '.join(u['roles'])}")

    print("═" * 52 + "\n")


def save_json_report(report: dict, path: str = "iam_report.json"):
    with open(path, "w") as f:
        json.dump(report, f, indent=2, default=str)
    print(f"📄  JSON report saved → {path}")


