def generate_ai_summary(report: dict) -> str:
    """Call OpenAI to generate a plain-English security summary."""
    if not OPENAI_KEY:
        print("ℹ️   OPENAI_API_KEY not set — skipping AI summary")
        return ""
    try:
        import openai
        client = openai.OpenAI(api_key=OPENAI_KEY)
        s = report["summary"]
        prompt = (
            f"You are a security analyst. Summarize the following Microsoft 365 IAM "
            f"findings in 2-3 concise sentences for a non-technical manager:\n\n"
            f"- Total users: {s['totalUsers']}\n"
            f"- Admin accounts: {s['totalAdmins']}\n"
            f"- Inactive users (>{INACTIVE_DAYS} days): {s['inactiveUsers']}\n"
            f"- High-risk accounts (inactive admins): {s['highRiskUsers']}\n"
            f"- Security issues (disabled accounts with roles): {s['securityIssues']}\n\n"
            "Be direct and action-oriented."
        )
        resp = client.chat.completions.create(
            model="gpt-4o-mini",
            messages=[{"role": "user", "content": prompt}],
            max_tokens=200,
        )
        summary = resp.choices[0].message.content.strip()
        print(f"🤖  AI Summary: {summary}")
        return summary
    except Exception as e:
        print(f"⚠️   OpenAI call failed: {e}")
        return ""


