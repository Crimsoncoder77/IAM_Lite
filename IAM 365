OPENAI_KEY    = os.getenv("OPENAI_API_KEY", "")

GRAPH_BASE    = "https://graph.microsoft.com/v1.0"
INACTIVE_DAYS = 30          # days since last login → INACTIVE

# ─────────────────────────────────────────────────────────
# 1. AUTHENTICATION — client credentials flow
# ─────────────────────────────────────────────────────────

def get_access_token() -> str:
    """Obtain a bearer token via OAuth2 client credentials."""
    url = f"https://login.microsoftonline.com/{TENANT_ID}/oauth2/v2.0/token"
    payload = {
        "grant_type":    "client_credentials",
        "client_id":     CLIENT_ID,
        "client_secret": CLIENT_SECRET,
        "scope":         "https://graph.microsoft.com/.default",
    }
    resp = requests.post(url, data=payload, timeout=30)
    resp.raise_for_status()
    token = resp.json().get("access_token", "")
    if not token:
        raise ValueError("Failed to obtain access token — check your credentials.")
    print("✅  Authenticated with Microsoft Graph API")
    return token


# ─────────────────────────────────────────────────────────
# 2. GRAPH API HELPERS
# ─────────────────────────────────────────────────────────

def graph_get(token: str, endpoint: str) -> list:
    """GET a Graph endpoint, handling @odata.nextLink pagination."""
    headers = {"Authorization": f"Bearer {token}"}
    results = []
    url = f"{GRAPH_BASE}{endpoint}"
    while url:
        resp = requests.get(url, headers=headers, timeout=30)
        resp.raise_for_status()
        data = resp.json()
        results.extend(data.get("value", []))
        url = data.get("@odata.nextLink")          # follow pages
    return results


# ─────────────────────────────────────────────────────────
# 3. DATA COLLECTION
# ─────────────────────────────────────────────────────────

def fetch_users(token: str) -> list:
    """Pull all users with sign-in activity fields."""
    # lastSignInDateTime requires AuditLog.Read.All OR
    # signInActivity is in beta — fall back to createdDateTime if absent
    raw = graph_get(
        token,
        "/users?$select=id,displayName,mail,userPrincipalName,"
        "accountEnabled,signInActivity,createdDateTime"
    )
    users = []
    for u in raw:
        sign_in = u.get("signInActivity") or {}
        last_login_raw = (
            sign_in.get("lastSignInDateTime")
            or u.get("createdDateTime")   # fallback
        )
        users.append({
            "id":             u.get("id", ""),
            "displayName":    u.get("displayName", ""),
            "email":          u.get("mail") or u.get("userPrincipalName", ""),
            "lastLogin":      last_login_raw,
            "accountEnabled": u.get("accountEnabled", True),
        })
    print(f"✅  Fetched {len(users)} users")
    return users


def fetch_directory_roles(token: str) -> list:
    """Pull activated directory roles."""
    roles = graph_get(token, "/directoryRoles")
    print(f"✅  Fetched {len(roles)} directory roles")
    return roles


def fetch_role_members(token: str, roles: list) -> list:
    """For each role, fetch its members → return list of (roleName, userId)."""
    assignments = []
    for role in roles:
        role_id   = role.get("id", "")
        role_name = role.get("displayName", "Unknown Role")
        try:
            members = graph_get(token, f"/directoryRoles/{role_id}/members")
            for m in members:
                assignments.append({
                    "roleName": role_name,
                    "userId":   m.get("id", ""),
                })
        except Exception:
            pass   # role may have no members — skip silently
    print(f"✅  Fetched {len(assignments)} role assignments")
    return assignments


