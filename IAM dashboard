<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>M365 IAM Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=IBM+Plex+Sans:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#0d0f14;--surface:#161a22;--border:#252b38;
  --accent:#4f9eff;--danger:#ff4d6d;--warn:#ffb347;
  --ok:#42d9a0;--admin:#c084fc;--text:#e2e8f0;--muted:#64748b;
  --font:'IBM Plex Sans',sans-serif;--mono:'IBM Plex Mono',monospace;
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:var(--font);min-height:100vh;padding:0 0 60px}
header{background:linear-gradient(135deg,#0d1117,#161a22);border-bottom:1px solid var(--border);padding:28px 40px;display:flex;align-items:center;justify-content:space-between}
.logo{display:flex;align-items:center;gap:12px}
.logo-icon{width:40px;height:40px;background:var(--accent);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px}
h1{font-size:1.4rem;font-weight:700;letter-spacing:-.02em}
.tagline{font-size:.75rem;color:var(--muted);margin-top:2px;font-family:var(--mono)}
.gen-at{font-size:.75rem;color:var(--muted);font-family:var(--mono)}
main{max-width:1280px;margin:0 auto;padding:40px 40px 0}
.stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin-bottom:36px}
.card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:24px 20px;position:relative;overflow:hidden;transition:transform .15s,border-color .15s}
.card:hover{transform:translateY(-2px);border-color:#333d52}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px}
.card-total::before{background:var(--accent)}
.card-admin::before{background:var(--admin)}
.card-inactive::before{background:var(--warn)}
.card-highrisk::before{background:var(--danger)}
.card-secissue::before{background:#ff2244}
.card-num{font-size:2.8rem;font-weight:700;font-family:var(--mono);line-height:1;margin-bottom:6px}
.card-total .card-num{color:var(--accent)}
.card-admin .card-num{color:var(--admin)}
.card-inactive .card-num{color:var(--warn)}
.card-highrisk .card-num{color:var(--danger)}
.card-secissue .card-num{color:#ff2244}
.card-label{font-size:.8rem;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:.08em}
.ai-box{background:linear-gradient(135deg,#1a1f2e,#1e2436);border:1px solid #2d3a5e;border-radius:12px;padding:24px 28px;margin-bottom:36px}
.ai-label{font-size:.75rem;font-weight:700;color:var(--accent);text-transform:uppercase;letter-spacing:.1em;margin-bottom:10px}
.ai-box p{line-height:1.7;color:#b0c4e8;font-size:.95rem}
.section-title{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);margin-bottom:14px;padding-bottom:8px;border-bottom:1px solid var(--border)}
.table-wrap{background:var(--surface);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:36px}
table{width:100%;border-collapse:collapse;font-size:.875rem}
thead tr{background:#1c2130}
th{text-align:left;padding:12px 16px;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--muted)}
td{padding:11px 16px;border-top:1px solid var(--border);vertical-align:middle}
tr:hover td{background:rgba(255,255,255,.02)}
tr.high-risk-row td{background:rgba(255,77,109,.05)}
tr.high-risk-row:hover td{background:rgba(255,77,109,.09)}
.mono{font-family:var(--mono);font-size:.8rem;color:var(--muted)}
.center{text-align:center}
.role-cell{font-size:.78rem;color:#94a3c8}
.badge{display:inline-block;padding:2px 8px;border-radius:4px;font-size:.7rem;font-weight:700;letter-spacing:.05em;font-family:var(--mono);margin:1px}
.badge-ok{background:rgba(66,217,160,.15);color:var(--ok)}
.badge-warn{background:rgba(255,179,71,.15);color:var(--warn)}
.badge-danger{background:rgba(255,77,109,.15);color:var(--danger)}
.badge-admin{background:rgba(192,132,252,.15);color:var(--admin)}
.filter-bar{display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap}
.filter-btn{background:var(--surface);border:1px solid var(--border);color:var(--muted);padding:6px 14px;border-radius:6px;font-size:.78rem;font-weight:600;font-family:var(--font);cursor:pointer;transition:all .15s}
.filter-btn:hover,.filter-btn.active{background:var(--accent);border-color:var(--accent);color:#fff}
.demo-banner{background:rgba(79,158,255,.1);border:1px solid rgba(79,158,255,.3);border-radius:8px;padding:10px 16px;margin-bottom:24px;font-size:.8rem;color:#7ab8ff;font-family:var(--mono)}
</style>
</head>
<body>
<header>
  <div class="logo">
    <div class="logo-icon">🛡️</div>
    <div>
      <h1>M365 IAM Analyzer</h1>
