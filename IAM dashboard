          <td class="center">45d</td>
          <td class="role-cell">Security Administrator</td>
          <td><span class="badge badge-warn">INACTIVE</span> <span class="badge badge-admin">ADMIN</span> <span class="badge badge-danger">HIGH_RISK</span></td>
        </tr>
        <tr class="high-risk-row">
          <td>🚫</td>
          <td>Dave Disabled</td>
          <td class="mono">dave@contoso.com</td>
          <td class="center">90d</td>
          <td class="role-cell">Global Administrator</td>
          <td><span class="badge badge-warn">INACTIVE</span> <span class="badge badge-admin">ADMIN</span> <span class="badge badge-danger">HIGH_RISK</span> <span class="badge badge-danger">SECURITY_ISSUE</span></td>
        </tr>
        <tr class="">
          <td>✅</td>
          <td>Eve Executive</td>
          <td class="mono">eve@contoso.com</td>
          <td class="center">2d</td>
          <td class="role-cell">Exchange Administrator</td>
          <td><span class="badge badge-admin">ADMIN</span></td>
        </tr>
        <tr class="high-risk-row">
          <td>🚫</td>
          <td>Frank Former</td>
          <td class="mono">frank@contoso.com</td>
          <td class="center">120d</td>
          <td class="role-cell">User Administrator</td>
          <td><span class="badge badge-warn">INACTIVE</span> <span class="badge badge-admin">ADMIN</span> <span class="badge badge-danger">HIGH_RISK</span> <span class="badge badge-danger">SECURITY_ISSUE</span></td>
        </tr>
        <tr class="">
          <td>✅</td>
          <td>Grace Ghost</td>
