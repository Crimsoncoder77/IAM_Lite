  <div class="table-wrap">
    <table id="userTable">
      <thead><tr><th>Status</th><th>Name</th><th>Email</th><th class="center">Last Login</th><th>Roles</th><th>Risk Flags</th></tr></thead>
      <tbody>
        <tr class="high-risk-row">
