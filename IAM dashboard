        </tr></tbody>
    </table>
  </div>
</main>
<script>
function filterTable(flag,btn){
  document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('#userTable tbody tr').forEach(row=>{
    if(flag==='all'){row.style.display='';return}
    const flags=Array.from(row.querySelectorAll('.badge')).map(b=>b.textContent.trim());
    row.style.display=flags.includes(flag)?'':'none';
  });
}
</script>
</body>
</html>
